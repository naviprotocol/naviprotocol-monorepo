{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "baseUrl": "../..",
    "declaration": false,
    "esModuleInterop": true,
    "isolatedModules": true,
    "lib": ["DOM", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"],
    "paths": {
      "@naviprotocol/astros-aggregator-sdk": [
        "packages/astros-aggregator-sdk/src/index.ts"
      ],
      "@naviprotocol/astros-bridge-sdk": ["packages/astros-bridge-sdk/src/index.ts"],
      "@naviprotocol/astros-dca-sdk": ["packages/astros-dca-sdk/src/index.ts"],
      "@naviprotocol/lending": ["packages/lending/src/index.ts"],
      "@naviprotocol/wallet-client": ["packages/wallet-client/src/index.ts"],
      "@mysten/sui/*": [
        "node_modules/.pnpm/@mysten+sui@2.17.0_typescript@5.8.3/node_modules/@mysten/sui/dist/*/index.d.mts",
        "node_modules/.pnpm/@mysten+sui@2.17.0_typescript@5.8.3/node_modules/@mysten/sui/dist/*.d.mts"
      ]
    }
  },
  "include": ["./sdk-v2-smoke.ts"]
}
