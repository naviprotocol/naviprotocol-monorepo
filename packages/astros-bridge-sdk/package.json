{
  "name": "@naviprotocol/astros-bridge-sdk",
  "version": "2.0.0",
  "description": "NAVI Astros Aggregator SDK",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "navi",
    "astros",
    "aggregator",
    "sui"
  ],
  "author": "NAVI",
  "homepage": "https://sdk.naviprotocol.io/bridge",
  "bugs": "https://github.com/naviprotocol/naviprotocol-monorepo/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/naviprotocol/naviprotocol-monorepo.git"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "source": "src/index.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "run-p build:lib",
    "build:lib": "vite build",
    "prettier": "prettier --check src/",
    "prettier:fix": "prettier --write src/",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "verify": "run-p prettier lint",
    "verify:fix": "run-p prettier:fix lint:fix",
    "test": "vitest --config ./vite.config.unit.js",
    "test:types": "pnpm build:lib && tsc --noEmit -p tsconfig.json",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typedoc": "typedoc"
  },
  "dependencies": {
    "@solana/web3.js": "1.98.2",
    "axios": "1.13.2",
    "ethers": "6.13.5"
  },
  "devDependencies": {
    "@mayanfinance/swap-sdk": "15.0.0",
    "@mysten/sui": "2.20.2",
    "@types/node": "22.7.5",
    "tsconfig-paths": "4.2.0",
    "tslint": "6.1.3",
    "typescript": "5.8.3",
    "vitest": "3.2.4"
  },
  "peerDependencies": {
    "@mysten/sui": ">=2.0.0"
  }
}
