{
  "name": "@naviprotocol/wallet-client",
  "version": "2.0.0-beta.1",
  "description": "NAVI Wallet Client",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "navi",
    "sui"
  ],
  "author": "NAVI",
  "homepage": "https://sdk.naviprotocol.io/wallet-client",
  "bugs": "https://github.com/naviprotocol/naviprotocol-monorepo/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/naviprotocol/naviprotocol-monorepo.git"
  },
  "main": "dist/index.esm.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "source": "src/index.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "run-p build:lib",
    "build:lib": "vite build",
    "prettier": "prettier --check src/",
    "prettier:fix": "prettier --write src/",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "verify": "run-p prettier lint",
    "verify:fix": "run-p prettier:fix lint:fix",
    "test": "vitest --config ./vite.config.unit.js",
    "test:types": "pnpm --filter @naviprotocol/lending build:lib && pnpm --filter @naviprotocol/astros-aggregator-sdk build:lib && pnpm --filter @naviprotocol/astros-dca-sdk build:lib && pnpm build:lib && tsc --noEmit -p tsconfig.type-tests.json",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typedoc": "typedoc"
  },
  "dependencies": {
    "@naviprotocol/astros-aggregator-sdk": "workspace:*",
    "@naviprotocol/lending": "workspace:*",
    "axios": "1.13.2",
    "bignumber.js": "9.1.2",
    "date-fns": "4.1.0",
    "mitt": "3.0.1",
    "shio-sdk": "1.0.9"
  },
  "devDependencies": {
    "@mysten/bcs": "2.0.1",
    "@mysten/sui": "2.19.0",
    "@pythnetwork/pyth-sui-js": "2.2.0",
    "@suilend/sdk": "3.0.4",
    "@suilend/sui-fe": "3.0.7",
    "@types/node": "22.7.5",
    "dotenv": "16.4.7",
    "tsconfig-paths": "4.2.0",
    "tslint": "6.1.3",
    "typescript": "5.8.3",
    "vitest": "3.2.2"
  },
  "peerDependencies": {
    "@mysten/sui": ">=2.0.0",
    "@mysten/bcs": "2.0.1",
    "@pythnetwork/pyth-sui-js": "2.2.0",
    "@suilend/sdk": "^3.0.4",
    "@suilend/sui-fe": "^3.0.7"
  },
  "peerDependenciesMeta": {
    "@mysten/bcs": {
      "optional": true
    },
    "@pythnetwork/pyth-sui-js": {
      "optional": true
    },
    "@suilend/sdk": {
      "optional": true
    },
    "@suilend/sui-fe": {
      "optional": true
    }
  }
}
